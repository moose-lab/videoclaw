# === LLM Providers ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
MOONSHOT_API_KEY=sk-...  # Kimi (月之暗面) API Key

# === Video Model Providers ===
# SORA_API_KEY=          # OpenAI Sora (uses OPENAI_API_KEY)
# RUNWAY_API_KEY=
# KLING_API_KEY=

# === Audio Providers ===
# ELEVENLABS_API_KEY=
# SUNO_API_KEY=

# === VideoClaw Config ===
VIDEOCLAW_PROJECTS_DIR=./projects
VIDEOCLAW_MODELS_DIR=./models_cache
VIDEOCLAW_DEFAULT_LLM=openai/moonshot-v1-8k  # 支持: gpt-4o, openai/moonshot-v1-8k, openai/moonshot-v1-32k, openai/moonshot-v1-128k
VIDEOCLAW_DEFAULT_VIDEO_MODEL=mock
VIDEOCLAW_LOG_LEVEL=info
